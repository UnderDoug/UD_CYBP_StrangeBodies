      <part Type="UD_CYBP Tentacle" Laterality="Lower Left">
        <part Type="UD_CYBP Suckers" Laterality="Lower Left" SupportsDependent="Lower WornOnSuckers" />
      </part>
      
      <part Type="Missile Weapon" Laterality="Outer" />
      <part Type="Missile Weapon" Laterality="Inner" />

      <part Type="UD_CYBP WornOnSuckers" Laterality="Upper" DependsOn="Upper WornOnSuckers" />
      <part Type="UD_CYBP WornOnSuckers" Laterality="Outer" DependsOn="Outer WornOnSuckers" />
      <part Type="UD_CYBP WornOnSuckers" Laterality="Inner" DependsOn="Inner WornOnSuckers" />
      <part Type="UD_CYBP WornOnSuckers" Laterality="Lower" DependsOn="Lower WornOnSuckers" />
      
    </anatomy>

