  <anatomies>
    <!--
    
    Octopod
    
    -->
    <anatomy Name="UD_CYBP Octopod" BodyType="UD_CYBP FootBody" Category="Mollusk">
      
      <part Type="UD_CYBP Tentacle" Laterality="Upper Right">
        <part Type="UD_CYBP Suckers" Laterality="Upper Right" SupportsDependent="Upper WornOnSuckers" />
      </part>
      <part Type="UD_CYBP Tentacle" Laterality="Upper Left">
        <part Type="UD_CYBP Suckers" Laterality="Upper Left" SupportsDependent="Upper WornOnSuckers" />
      </part>

      <part Type="UD_CYBP Tentacle" Laterality="Outer Right">
        <part Type="UD_CYBP Suckers" Laterality="Outer Right" SupportsDependent="Outer WornOnSuckers" />
      </part>
      <part Type="UD_CYBP Tentacle" Laterality="Outer Left">
        <part Type="UD_CYBP Suckers" Laterality="Outer Left" SupportsDependent="Outer WornOnSuckers" />
      </part>
      
      <part Type="UD_CYBP Rostrum" />

      <part Type="UD_CYBP Tentacle" Laterality="Inner Right">
        <part Type="UD_CYBP Suckers" Laterality="Inner Right" SupportsDependent="Inner WornOnSuckers" />
      </part>
      <part Type="UD_CYBP Tentacle" Laterality="Inner Left">
        <part Type="UD_CYBP Suckers" Laterality="Inner Left" SupportsDependent="Inner WornOnSuckers" />
      </part>

      <part Type="UD_CYBP Tentacle" Laterality="Lower Right">
        <part Type="UD_CYBP Suckers" Laterality="Lower Right" SupportsDependent="Lower WornOnSuckers" />
