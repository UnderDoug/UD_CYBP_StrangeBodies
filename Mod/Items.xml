<?xml version="1.0" encoding="utf-8" ?>
<objects>

  <object Name="UD_CYBP Suckers" Inherits="NaturalWeapon">
    <part Name="Render" DisplayName="suckers"
          ColorString="&amp;w" RenderString="S"
          Tile="Creatures/natural-weapon-suckers.png"
          TileColor="&amp;w" DetailColor="W" />
    <part Name="MeleeWeapon"
          MaxStrengthBonus="999"
          BaseDamage="1d2"
          Skill="Cudgel" Stat="Strength"
          Slot="Hand" />
    <tag Name="SwingSound" Value="sfx_melee_naturalWeapon_fist_swing" />
    <tag Name="BlockedSound" Value="sfx_melee_naturalWeapon_fist_blocked" />
  </object>

  <!--
  
  Stomatopod
  
  -->
  <object Name="UD_CYBP Stomatopod Mandibles" Inherits="NaturalWeapon">
    <part Name="Render" DisplayName="large mandibles"
          ColorString="&amp;w" RenderString="W"
          Tile="Creatures/natural-weapon-mandible.bmp"
          TileColor="&amp;w" DetailColor="W" />
    <part Name="MeleeWeapon"
          MaxStrengthBonus="999"
          BaseDamage="1d3"
          Skill="Axe" Stat="Strength"
          Slot="Head" />
    <tag Name="Gender" Value="plural" />
  </object>
  <object Name="UD_CYBP Stomatopod Rake" Inherits="NaturalWeapon">
    <part Name="Render" DisplayName="rake"
          ColorString="&amp;w" RenderString="K"
          Tile="Creatures/natural-weapon-pincer.bmp"
          TileColor="&amp;w" DetailColor="W" />
    <part Name="MeleeWeapon"
          MaxStrengthBonus="999"
          BaseDamage="1d2-1"
          Skill="ShortBlades" Stat="Strength"
          Slot="Hand" />
    <tag Name="SwingSound" Value="Sounds/Melee/longBlades/sfx_melee_longBlade_saltHopperMandible_swing" />
    <tag Name="BlockedSound" Value="Sounds/Melee/multiUseBlock/sfx_melee_longBlade_saltHopperMandible_blocked" />
  </object>
  <!-- Pistol Variant -->
  <object Name="UD_CYBP Stomatopod Pistol Claw Pistol" Inherits="MissileWeapon">
    <part Name="Render" DisplayName="pistol claw"
          RenderString="L" ColorString="&amp;w"
          Tile="Items/sw_fleshgun.bmp"
          TileColor="&amp;w" DetailColor="B" />
    <part Name="Description" Short="Evolutionary pressure has molded the dactyl joints, adhesive plaques, and a tooth-cavity system into a pistol-like claw that supports snapping with such force that it tears a tiny cavity in the air in front of it. This cavity violently implodes, producing sonoluminescence, with the aid of the weight of the atmosphere." />
    <part Name="Physics" Weight="1" Organic="true" />
    <part Name="MissileWeapon"
          WeaponAccuracy="12" RangeIncrement="6"
          AmmoChar="&amp;B*"
          Skill="Pistol"
          SlotType="Missile Weapon" />
    <part Name="BioAmmoLoader"
          MaxCapacity="1" Available="1" TurnsToGenerate="5"
          IsRealityDistortionBased="false"
          IsEMPSensitive="false"
          IsRustSensitive="false"
          ProjectileObject="Projectile_UD_CYBP Stomatopod Pistol Claws_Energy" />
    <tag Name="UsesSlots" Value="Missile Weapon" />
    <removepart Name="TinkerItem" />
    <intproperty Name="Natural" Value="1" />
    <part Name="NaturalEquipment" />
    <part Name="Cursed" RevealInDescription="false" />
    <part Name="NoBreak" />
    <part Name="NoDamage" />
    <part Name="NoRust" />
    <intproperty Name="Bleeds" Value="1" />
    <tag Name="BleedLiquid" Value="blood-1000" />
    <tag Name="LiveAnimal" />
    <tag Name="ExcludeFromDynamicEncounters" />
    <tag Name="NaturalGear" />
    <tag Name="NoDefaultBehavior" />
    <tag Name="NoSparkingQuest" />
    <tag Name="ShowAsPhysicalFeature" />
    <stag Name="Contemporary" />
    <tag Name="MissileFireSound" Value="Sounds/Missile/Fires/Pistols/sfx_missile_psychalFleshgun_fire" />
  </object>
  <object Name="Projectile_UD_CYBP Stomatopod Pistol Claws_Energy" Inherits="TemporaryEnergyProjectile">
    <part Name="Render" DisplayName="sonic blast"
          RenderString="*" ColorString="&amp;B"
          TileColor="&amp;B" DetailColor="c" />
    <part Name="Projectile" BasePenetration="8" BaseDamage="1d6" ColorString="&amp;B" PassByVerb="pop" />
  </object>

  <!-- Variant Base -->
  <object Name="UD_CYBP Stomatopod Base Claw" Inherits="NaturalWeapon">
    <part Name="Render" DisplayName="claw"
          ColorString="&amp;w"
          Tile="Creatures/natural-weapon-pincer.bmp"
          TileColor="&amp;w" DetailColor="W" />
    <part Name="MeleeWeapon"
          MaxStrengthBonus="999"
          BaseDamage="1d4"
          Stat="Strength"
          Slot="Hand" />
    <tag Name="SwingSound" Value="Sounds/Melee/longBlades/sfx_melee_longBlade_saltHopperMandible_swing" />
    <tag Name="BlockedSound" Value="Sounds/Melee/multiUseBlock/sfx_melee_longBlade_saltHopperMandible_blocked" />
    <tag Name="BaseObject" Value="*noinherit" />
  </object>
  <!-- Spear Variant-->
  <object Name="UD_CYBP Stomatopod Spear Claw" Inherits="UD_CYBP Stomatopod Base Claw">
    <part Name="Render" DisplayName="spear claw" RenderString="Y" Tile="Items/sw_longblade_13.bmp" />
    <part Name="MeleeWeapon" Skill="LongBlades" />
  </object>
  <!-- Smasher Variant-->
  <object Name="UD_CYBP Stomatopod Smasher Claw" Inherits="UD_CYBP Stomatopod Base Claw">
    <part Name="Render" DisplayName="smasher claw" RenderString="B" Tile="Creatures/natural-weapon-knob.bmp" />
    <part Name="MeleeWeapon" Skill="Cudgel" />
  </object>
  <!-- Hatchet Variant-->
  <object Name="UD_CYBP Stomatopod Hatchet Claw" Inherits="UD_CYBP Stomatopod Base Claw">
    <part Name="Render" DisplayName="hatchet claw" RenderString="J" Tile="Creatures/natural-weapon-shovel.bmp" />
    <part Name="MeleeWeapon" Skill="Axe" />
  </object>
  
